# Required trading credentials
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET=your_alpaca_secret

# Optional APIs
NEWS_API_KEY=

# Runtime controls
DAILY_MAX_TRADES=1000
MAX_POSITION_PCT=0.03
STOP_LOSS_PCT=0.03
TAKE_PROFIT_PCT=0.05
LOOP_INTERVAL_SECONDS=300
MAX_DAILY_DRAWDOWN_PCT=0.05
MAX_PORTFOLIO_HEAT_PCT=0.20

# Optional ticker override (comma-separated)
# TICKERS=SPY,QQQ,AAPL

# Optional Ollama overrides
OLLAMA_MODEL=llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434
SKIP_OLLAMA_HEALTHCHECK=false

# Optional alerts
ALERTS_ENABLED=false
ALERT_WEBHOOK_URL=
ALERT_TIMEOUT_SECONDS=5

# Optional secrets vault JSON path and docker secrets directory
SECRETS_VAULT_FILE=
SECRETS_DIR=/run/secrets
